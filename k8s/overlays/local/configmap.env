DB_HOST=mysql
DB_PORT=20000

DB_URL=jdbc:mysql://mysql:20000/travelx?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8

DB_USERNAME=travelx
DB_PASSWORD=travelGood

GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# 서버가 아니라 프론트엔드(client 레포)의 /auth/callback 풀 URL. Google Console의
# Authorized redirect URIs에도 이 값 그대로 등록돼 있어야 한다.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

JWT_SECRET=RRw234AewfKA#2K1J34RALDF

SPRING_PROFILES_ACTIVE=local
SPRING_PORT=8080

TOMCAT_MAX_CONNECTIONS=20000
TOMCAT_MAX_THREADS=600
TOMCAT_MIN_SPARE_THREADS=100

CORS_ALLOWED_ORIGINS=http://localhost:5173

DEV_AUTH_ENABLED=false

AUTH_COOKIE_SAME_SITE=None

# 최대 커넥션 풀 크기 (기본값: 8)
HIKARI_MAX_POOL_SIZE=8

# 최소 유휴 커넥션 수 (기본값: 8)
HIKARI_MIN_IDLE=8

# 커넥션 획득 대기 타임아웃 (ms) (기본값: 3000)
HIKARI_CONNECTION_TIMEOUT=3000

# 커넥션 유효성 검사 타임아웃 (ms) (기본값: 3000)
HIKARI_VALIDATION_TIMEOUT=3000

# 커넥션 유휴 상태 최대 유지 시간 (ms) (기본값: 300000 - 5분)
HIKARI_IDLE_TIMEOUT=300000

# 커넥션 최대 생명 주기 (ms) (기본값: 600000 - 10분)
HIKARI_MAX_LIFETIME=600000

# 커넥션 유실 방지 주기 (ms) (기본값: 60000 - 1분)
HIKARI_KEEPALIVE_TIME=60000

# 개별 파일당 최대 허용 용량 (기본값: 10MB)
MAX_FILE_SIZE=10MB

# 단일 요청당 최대 허용 용량 (기본값: 10MB)
MAX_REQUEST_SIZE=10MB

# DDL 자동 생성 옵션 (로컬은 update 또는 ddl-auto 제어 가능, 기본값/운영은 validate 권장)
DDL_AUTO=validate

# Java 21 가상 쓰레드(Virtual Threads) 활성화 여부 (기본값: true)
VIRTUAL_THREADS_ENABLED=true

# 비동기 작업 코어 풀 사이즈 (기본값: 5)
ASYNC_CORE_POOL_SIZE=5

# 비동기 작업 최대 풀 사이즈 (기본값: 5)
ASYNC_MAX_POOL_SIZE=5

# 비동기 작업 대기 큐 용량 (기본값: 100)
ASYNC_QUEUE_CAPACITY=100

# 로그 파일 저장 경로 (로컬 기본값: ./logs/app.log)
LOG_FILE_PATH=./logs/app.log