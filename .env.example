# ==============================================================================
# TravelX Server - Environment Variables Configuration Example (.env.example)
#
# 이 파일을 '.env' (또는 로컬 개발을 위해 'secret.env') 파일로 복사하여 실제 값을 설정하세요.
# .env 파일은 민감한 정보를 포함하므로 절대로 깃허브에 커밋하지 마십시오.
# ==============================================================================

# ==========================================
# 1. 필수 설정 (Required Settings)
# ==========================================

# 데이터베이스 연결 URL (예: MySQL)
# Format: jdbc:mysql://<HOST>:<PORT>/<DATABASE_NAME>?options
DB_URL=jdbc:mysql://localhost:3306/travelx?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8

# 데이터베이스 사용자 이름 및 비밀번호
DB_USERNAME=travelx
DB_PASSWORD=your_secure_db_password

# Google OAuth 2.0 Client ID / Secret (구글 소셜 로그인 연동에 필요)
# Google Cloud Console > APIs & Services > Credentials에서 발급받은 값을 입력하세요.
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 구글 인가 요청과 code 교환 양쪽에 정확히 동일하게 쓰이는 redirect_uri.
# 서버 URL이 아니라 프론트엔드(client 레포)의 /auth/callback 풀 URL이며,
# Google Cloud Console의 Authorized redirect URIs에도 이 값 그대로 등록돼 있어야 한다.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# JWT 토큰 서명용 비밀키
# HS256 알고리즘을 사용하므로, 256비트(32바이트) 이상의 무작위 문자열을 설정할 것을 권장합니다.
JWT_SECRET=your_super_secret_jwt_signing_key_at_least_32_characters_long

# Stripe 결제 연동 (discussion#16 방안 2: Hold→Pay 분리)
# Secret key: Stripe 대시보드 > Developers > API keys (테스트 모드는 sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Webhook signing secret: 로컬은 `stripe listen --forward-to localhost:8080/webhooks/stripe`
# 실행 시 출력되는 whsec_... 값, 운영은 Stripe 대시보드에 등록한 엔드포인트의 서명 시크릿
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here


# ==========================================
# 2. 선택 설정 (Optional Settings & Defaults)
# ==========================================

# ------------------------------------------
# 애플리케이션 및 WAS 설정 (Spring Boot / Tomcat)
# ------------------------------------------
# 활성 스프링 프로필 (기본값: local / 로컬 개발: local, 스테이징: staging, 운영: prod)
SPRING_PROFILES_ACTIVE=local

# 서버 포트 (기본값: 8080)
SPRING_PORT=8080

# Tomcat 최대 연결 수 (기본값: 20000)
TOMCAT_MAX_CONNECTIONS=20000

# Tomcat 최대 쓰레드 수 (기본값: 600)
TOMCAT_MAX_THREADS=600

# Tomcat 여유(최소) 쓰레드 수 (기본값: 100)
TOMCAT_MIN_SPARE_THREADS=100


# ------------------------------------------
# CORS 및 개발용 설정 (CORS & Dev Helper)
# ------------------------------------------
# 허용할 CORS Origin 목록 (쉼표로 구분, 기본값: http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 개발용 인증 도우미 엔드포인트 활성화 여부 (로컬 테스트용, 기본값: false)
DEV_AUTH_ENABLED=false

# 개발용 인증 쿠키 SameSite 설정 (기본값: None)
AUTH_COOKIE_SAME_SITE=None


# ------------------------------------------
# 데이터베이스 커넥션 풀 설정 (HikariCP)
# ------------------------------------------
# 최대 커넥션 풀 크기 (기본값: 8)
HIKARI_MAX_POOL_SIZE=8

# 최소 유휴 커넥션 수 (기본값: 8)
HIKARI_MIN_IDLE=8

# 커넥션 획득 대기 타임아웃 (ms) (기본값: 3000)
HIKARI_CONNECTION_TIMEOUT=3000

# 커넥션 유효성 검사 타임아웃 (ms) (기본값: 3000)
HIKARI_VALIDATION_TIMEOUT=3000

# 커넥션 유휴 상태 최대 유지 시간 (ms) (기본값: 300000 - 5분)
HIKARI_IDLE_TIMEOUT=300000

# 커넥션 최대 생명 주기 (ms) (기본값: 600000 - 10분)
HIKARI_MAX_LIFETIME=600000

# 커넥션 유실 방지 주기 (ms) (기본값: 60000 - 1분)
HIKARI_KEEPALIVE_TIME=60000


# ------------------------------------------
# 파일 업로드 용량 제한 설정 (Multipart)
# ------------------------------------------
# 개별 파일당 최대 허용 용량 (기본값: 10MB)
MAX_FILE_SIZE=10MB

# 단일 요청당 최대 허용 용량 (기본값: 10MB)
MAX_REQUEST_SIZE=10MB


# ------------------------------------------
# JPA & Hibernate 설정
# ------------------------------------------
# DDL 자동 생성 옵션 (로컬은 update 또는 ddl-auto 제어 가능, 기본값/운영은 validate 권장)
DDL_AUTO=validate


# ------------------------------------------
# 비동기 및 가상 쓰레드 설정 (Async & Thread Pool)
# ------------------------------------------
# Java 21 가상 쓰레드(Virtual Threads) 활성화 여부 (기본값: true)
VIRTUAL_THREADS_ENABLED=true

# 비동기 작업 코어 풀 사이즈 (기본값: 5)
ASYNC_CORE_POOL_SIZE=5

# 비동기 작업 최대 풀 사이즈 (기본값: 5)
ASYNC_MAX_POOL_SIZE=5

# 비동기 작업 대기 큐 용량 (기본값: 100)
ASYNC_QUEUE_CAPACITY=100


# ------------------------------------------
# 로깅 설정 (Logging)
# ------------------------------------------
# 로그 파일 저장 경로 (로컬 기본값: ./logs/app.log)
LOG_FILE_PATH=./logs/app.log
