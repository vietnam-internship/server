<?xml version="1.0" encoding="UTF-8"?>
<!-- local: 콘솔 전용, 개발 중 SQL/요청 흐름을 최대한 자세히 -->
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%clr(%d{HH:mm:ss.SSS}){faint}|%clr(%-5level)|%clr(%-40.40logger{39}){cyan}|%m%n%wEx</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- 애플리케이션 -->
  <logger name="com.fptis.intern.server" level="DEBUG"/>

  <!-- SQL 쿼리 + 바인딩 파라미터 (바인딩은 TRACE에서만 출력됨) -->
  <logger name="org.hibernate.SQL" level="DEBUG"/>
  <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>

  <!-- 요청 매핑/디스패치 흐름 -->
  <logger name="org.springframework.web" level="DEBUG"/>
  <logger name="org.springframework.web.servlet.DispatcherServlet" level="INFO"/>

  <!-- 트랜잭션 경계 확인이 필요할 때만 DEBUG로 올려 사용 -->
  <logger name="org.springframework.transaction.interceptor" level="INFO"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
