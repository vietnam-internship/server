<?xml version="1.0" encoding="UTF-8"?>
<!-- staging: 콘솔 + 파일(7일 보관), QA 디버깅을 위해 앱 로그는 DEBUG, SQL은 기본 OFF -->
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <property name="LOG_PATH" value="${LOG_FILE_PATH:-./logs/app.log}"/>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%clr(%d{HH:mm:ss.SSS}){faint}|%clr(%-5level)|%clr(%-40.40logger{39}){cyan}|%m%n%wEx</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}</file>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS}|%-5level|%-40.40logger{39}|%m%n%ex</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
      <maxFileSize>50MB</maxFileSize>
      <maxHistory>7</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- 애플리케이션: QA 이슈 추적을 위해 DEBUG 유지 -->
  <logger name="com.fptis.intern.server" level="DEBUG"/>

  <!-- SQL은 기본 OFF(INFO), 쿼리 확인이 필요할 때만 DEBUG로 내려 사용 -->
  <logger name="org.hibernate.SQL" level="INFO"/>

  <logger name="org.springframework.web" level="INFO"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
    <appender-ref ref="FILE"/>
  </root>
</configuration>
